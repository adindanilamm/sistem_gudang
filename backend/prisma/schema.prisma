// ===========================================================
// Prisma Schema — StockFlow
// Database: MySQL (stockflow_db)
// ===========================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ===========================================================
// MODEL 1: User
// Menyimpan data akun Manager dan Karyawan.
// ===========================================================
model User {
  id         Int           @id @default(autoincrement())
  username   String        @unique @db.VarChar(50)
  password   String        @db.VarChar(255)
  name       String        @db.VarChar(100)
  role       Role          @default(karyawan)
  phone      String?       @db.VarChar(20)
  email      String?       @db.VarChar(100)
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt

  // Relasi: satu User bisa punya banyak transaksi
  transactions Transaction[] @relation("UserTransactions")

  @@map("users")
}

// ===========================================================
// MODEL 2: Item
// Master data barang. Stok dihitung dari transaksi.
// ===========================================================
model Item {
  kode       String        @id @db.VarChar(50)
  nama       String        @db.VarChar(150)
  satuan     String        @db.VarChar(20)
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt

  // Relasi: satu Item bisa punya banyak transaksi
  transactions Transaction[] @relation("ItemTransactions")

  @@map("items")
}

// ===========================================================
// MODEL 3: Transaction
// Mencatat seluruh aktivitas barang masuk dan keluar.
// ===========================================================
model Transaction {
  id     Int             @id @default(autoincrement())
  kode   String          @db.VarChar(50)
  type   TransactionType
  jumlah Int
  user   String          @db.VarChar(50)
  date   DateTime        @default(now())

  // Relasi ke tabel items (ON DELETE CASCADE)
  item   Item @relation("ItemTransactions", fields: [kode], references: [kode], onDelete: Cascade, onUpdate: Cascade)

  // Relasi ke tabel users (ON DELETE RESTRICT)
  userRef User @relation("UserTransactions", fields: [user], references: [username], onDelete: Restrict, onUpdate: Cascade)

  @@index([kode])
  @@index([user])
  @@index([date])
  @@index([type])
  @@map("transactions")
}

// ===========================================================
// ENUM
// ===========================================================
enum Role {
  manager
  karyawan
}

enum TransactionType {
  masuk
  keluar
}
