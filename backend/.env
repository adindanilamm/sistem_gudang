# ================================================================
# Koneksi Database MySQL — StockFlow
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# ================================================================

# Default XAMPP/Laragon: user=root, password kosong, port=3306
DATABASE_URL="mysql://root:@localhost:3306/stockflow_db"

# Jika pakai password MySQL, ubah menjadi:
# DATABASE_URL="mysql://root:passwordmu@localhost:3306/stockflow_db"
